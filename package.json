    "configuration": {
      "title": "Cloudsmith",
      "properties": {
        "cloudsmith-vsc.useLegacyWebApp": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, the extension will use the legacy webapp 'cloudsmith.io' for platform links."
        },
        "cloudsmith-vsc.inspectOutput": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, inspect will create a new text document with the results. By default it sends to Output tab."
        },
        "cloudsmith-vsc.showMaxPackages": {
          "type": "integer",
          "default": 30,
          "maximum": 30,
          "minimum": 1,
          "description": "Set the maximum number of packages to be returned per repository. Current maximum is 30. "
        },
        "cloudsmith-vsc.groupByPackageGroups": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, packages are displayed via Package Group."
        },
        "cloudsmith-vsc.showPermissibilityIndicators": {
          "type": "boolean",
          "default": true,
          "description": "Show visual indicators for package permissibility status (quarantined, policy violations). When disabled, format-based icons are used for all packages."
        },
        "cloudsmith-vsc.searchPageSize": {
          "type": "integer",
          "default": 50,
          "minimum": 10,
          "maximum": 100,
          "description": "Number of results per page when searching packages."
        },
        "cloudsmith-vsc.recentSearches": {
          "type": "integer",
          "default": 10,
          "minimum": 0,
          "maximum": 50,
          "description": "Number of recent searches to remember."
        },
        "cloudsmith-vsc.defaultWorkspace": {
          "type": "string",
          "default": "",
          "description": "Cloudsmith workspace slug to use by default. When set, repositories load directly without a workspace picker. Leave empty to show all accessible workspaces."
        },
        "cloudsmith-vsc.autoScanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan project dependencies against Cloudsmith when a workspace is opened. Requires a configured Cloudsmith workspace."
        },
        "cloudsmith-vsc.dependencyScanWorkspace": {
          "type": "string",
          "default": "",
          "description": "Cloudsmith workspace slug to use for dependency health scanning. Leave empty to be prompted each time."
        },
        "cloudsmith-vsc.dependencyScanRepo": {
          "type": "string",
          "default": "",
          "description": "Cloudsmith repository slug to use for dependency health scanning. Leave empty for workspace-wide search."
        },
        "cloudsmith-vsc.maxDependenciesToScan": {
          "type": "integer",
          "default": 200,
          "minimum": 1,
          "description": "Maximum number of dependencies to scan before truncating a dependency health run."
        },
        "cloudsmith-vsc.showLicenseIndicators": {
          "type": "boolean",
          "default": true,
          "description": "Show license risk classification on packages. When disabled, license nodes are hidden."
        },
        "cloudsmith-vsc.showDockerDigestCommand": {
          "type": "boolean",
          "default": false,
          "description": "Show an additional 'Pull by digest' option for Docker install commands. Digest-based pulls pin to an exact image for reproducibility."
        },
        "cloudsmith-vsc.experimentalSSOBrowser": {
          "type": "boolean",
          "default": false,
          "description": "Experimental: Attempt browser-based SSO authentication directly via SAML redirect. Falls back to CLI import if this fails. Enable to help debug the SSO token exchange."
        },
        "cloudsmith-vsc.resolveTransitiveDependencies": {
          "type": "boolean",
          "default": false,
          "description": "Use package manager CLI to resolve transitive (indirect) dependencies. Requires the package manager to be installed and dependencies to be installed in the project."
        },
        "cloudsmith-vsc.showLegacyPolicies": {
          "type": "boolean",
          "default": false,
          "description": "Show legacy classic policy violation fields (deny, license, vulnerability). Disable if your workspace only uses Enterprise Policy Manager."
        },
        "cloudsmith-vsc.restrictiveLicenses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["AGPL-3.0", "GPL-3.0", "GPL-2.0", "SSPL-1.0"],
          "description": "SPDX identifiers to treat as restrictive. Packages with these licenses will be flagged. These extend the built-in restrictive set."
        },
        "cloudsmith-vsc.promotionPipeline": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Optional ordered list of repository slugs for your promotion pipeline (e.g., ['dev', 'staging', 'production']). When set, promotion suggests the next repo in the pipeline. When empty, all workspace repos are shown."
        },
        "cloudsmith-vsc.promotionTags": {
          "type": "object",
          "default": {
            "onPromote": ["promoted-to-{target}", "approved-{date}"],
            "onReceive": ["promoted-from-{source}"]
          },
          "description": "Tag templates applied when promoting packages. Supports {target}, {source}, {date} placeholders."
        },
        "cloudsmith-vsc.showEntitlements": {
          "type": "boolean",
          "default": false,
          "description": "Show active entitlement tokens under each repository. Useful for debugging download access issues."
        },
        "cloudsmith-vsc.showRepoMetrics": {
          "type": "boolean",
          "default": false,
          "description": "Show storage and bandwidth usage indicators on repositories."
        }
      }
    }
  },
